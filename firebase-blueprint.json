{
  "entities": {
    "Issue": {
      "title": "Issue",
      "description": "Civic report ticket for public hazards and service requests",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "dnaId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string" },
        "dangerScore": { "type": "integer" },
        "photoBefore": { "type": "string" },
        "photoAfter": { "type": "string" },
        "address": { "type": "string" },
        "wardId": { "type": "string" },
        "departmentId": { "type": "string" },
        "status": { "type": "string" },
        "slaDueAt": { "type": "string" },
        "escalationLevel": { "type": "integer" },
        "verifications": { "type": "integer" },
        "complaintText": { "type": "string" },
        "rtiText": { "type": "string" },
        "socialPostText": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "dnaId", "title", "description", "category", "severity", "dangerScore", "photoBefore", "wardId", "status", "createdAt"]
    },
    "Ward": {
      "title": "Ward",
      "description": "Municipal administrative zone tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "officer": { "type": "string" },
        "totalCount": { "type": "integer" },
        "resolvedCount": { "type": "integer" },
        "slaHitRate": { "type": "integer" }
      },
      "required": ["id", "name", "officer", "totalCount", "resolvedCount", "slaHitRate"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Citizen profile containing points and reward levels",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "points": { "type": "integer" },
        "verifications": { "type": "integer" },
        "level": { "type": "string" }
      },
      "required": ["name", "points", "verifications", "level"]
    }
  },
  "firestore": {
    "/issues/{issueId}": {
      "schema": "Issue",
      "description": "Grievance and incident tickets list"
    },
    "/wards/{wardId}": {
      "schema": "Ward",
      "description": "Ward statistics list"
    },
    "/profile/{profileId}": {
      "schema": "UserProfile",
      "description": "User profiles database"
    }
  }
}
